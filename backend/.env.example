# ============================================
# SakshyaAI — Environment Variables
# Copy this file to .env and fill in your values
# ============================================

# Server
PORT=3000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/sakshyaai

# Redis (for BullMQ)
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=sakshyaai_super_secret_key_change_in_prod
JWT_EXPIRES_IN=7d

# Twilio (use test credentials for dev)
TWILIO_ACCOUNT_SID=ACtest00000000000000000000000000
TWILIO_AUTH_TOKEN=test_auth_token_00000000000000
TWILIO_PHONE_NUMBER=+15005550006

# Base URL (for Twilio webhooks)
BASE_URL=http://localhost:3000

# AWS S3
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-south-1
S3_BUCKET_NAME=sakshyaai-evidence

# Verification Thresholds
GPS_THRESHOLD_METERS=500
EVIDENCE_TIMEOUT_HOURS=24

# Mock Mode (set to true for demo without real Twilio/S3)
MOCK_MODE=true
