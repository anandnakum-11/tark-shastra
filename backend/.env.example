# SakshyaAI backend environment
# Copy this file to backend/.env and replace placeholder values.

# Server
PORT=5001
NODE_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=grievance_db
DB_USER=postgres
DB_PASSWORD=postgres

# Redis is optional. If Redis is unavailable, the backend logs a warning and runs direct processing mode.
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=change_this_secret_before_deployment
JWT_EXPIRES_IN=7d

# Twilio IVR
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+15005550006

# Optional test override. When set, all IVR calls go to this number instead of the citizen profile phone.
TO_PHONE_NUMBER=

# Local backend URL used by the app.
BASE_URL=http://localhost:5001

# Public HTTPS backend URL used by real Twilio webhooks.
# For local real-call testing, run `ngrok http 5001` and paste the HTTPS URL here.
PUBLIC_BASE_URL=

# Use true for local demo without live Twilio calls.
MOCK_MODE=true

# IVR audio prompt. Leave empty to use the bundled Gujarati prompt at /api/ivr/audio/gj_audio.mp3.
IVR_AUDIO_URL=

# Optional Cloudinary evidence photo storage. Leave empty to store evidence locally under backend/uploads.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=sakshyaai/evidence

# Verification settings
GPS_THRESHOLD_METERS=50
EVIDENCE_TIMEOUT_HOURS=24
